T5_SD_MAP = {
    "enc.blk": "blocks",
    "token_embd": "token_embedding",
    "enc.output_norm": "norm",
    "attn_norm": "norm1",
    "attn_q": "attn.q",
    "attn_k": "attn.k",
    "attn_v": "attn.v",
    "attn_o": "attn.o",
    "attn_rel_b": "pos_embedding.embedding",
    "ffn_up": "ffn.fc1",
    "ffn_down": "ffn.fc2",
    "ffn_gate": "ffn.gate.0",
    "ffn_norm": "norm2",

    # "attn_q": "layer.0.SelfAttention.q",
